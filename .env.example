APP_NAME=SkinsArena
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_LOCALE=ru
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=skinsarena
DB_USERNAME=skinsarena
DB_PASSWORD=secret

SESSION_DRIVER=redis
QUEUE_CONNECTION=redis
CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379

# Почта: Mailpit (docker-compose / docker-compose.prod). Веб-интерфейс: http://localhost:8080/mailpit/ (прод: https://<домен>/mailpit/)
# В контейнерах Laravel хост SMTP — `mailpit`. Если запускаешь artisan с хоста, а Mailpit в Docker: MAIL_HOST=127.0.0.1
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
VITE_DEV_SERVER_URL=http://localhost:5173
# Обязательно при npm run dev: тот же URL, что APP_URL (где крутится Laravel). Иначе Steam OpenID висит/сбрасывается — сессия на 8080, а ты заходил с 5173.
VITE_BACKEND_URL=http://localhost:8080

# SPA: редирект после Steam callback и CORS
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1,127.0.0.1:5173

# Steam OpenID (client_secret у провайдера = Web API Key).
# Тот же ключ используется для ISteamUser/GetPlayerBans (проверка trade / economy ban при выставлении лота).
STEAM_API_KEY=
# Проверка ограничений обмена Steam при создании продажи (нужен STEAM_API_KEY). false — отключить (только для отладки).
# SKINSARENA_STEAM_TRADE_BAN_CHECK=false
# SKINSARENA_STEAM_WEB_API_TIMEOUT=10
# STEAM_REDIRECT_URI="${APP_URL}/auth/steam/callback"
# STEAM_ALLOWED_RETURN_HOSTS=localhost,127.0.0.1

# Первый администратор Filament (/admin); после смены .env: php artisan db:seed
ADMIN_EMAIL=admin@skinsarena.local
ADMIN_PASSWORD=change-me-in-production
ADMIN_STEAM_ID=76561198000000001

# Справочник скинов CS2 (ETL): JSON по URL, см. documentation/08-skin-catalog-sync.md
# SKIN_CATALOG_SOURCE_URL=https://raw.githubusercontent.com/ByMykel/CSGO-API/main/public/api/en/skins.json
# SKIN_CATALOG_HTTP_TIMEOUT=120

# Инвентарь Steam (Community JSON): см. config/skinsarena.php → steam_inventory
# Прод: CS2 → app_id 730, context_id 2
# Временный тест с Dota 2 (предметы из Dota-инвентаря):
# SKINSARENA_STEAM_INVENTORY_APP_ID=570
# SKINSARENA_STEAM_INVENTORY_CONTEXT_ID=2
# SKINSARENA_STEAM_INVENTORY_GAME_LABEL="Dota 2"
# Показывать в ЛК только торгуемые (по умолчанию да). false — видеть и неторгуемые (Dota часто без tradable):
# SKINSARENA_STEAM_INVENTORY_ONLY_TRADABLE=false
# Если Steam отвечает 403 с сервера/Docker: http://user:pass@host:port или socks5://127.0.0.1:1080
# SKINSARENA_STEAM_INVENTORY_HTTP_PROXY=
# Верни 730 и подпись CS2 перед продом. Парсинг износа/редкости заточен под CS2; для Dota возможны грубые дефолты.
